import json
import time
import sys

# ============================================================
#  COLOR SYSTEM (Matrix Hacker Style)
# ============================================================

class Color:
    RESET = "\033[0m"
    BOLD = "\033[1m"

    MATRIX = "\033[92m"       # Bright green
    MATRIX_DARK = "\033[32m"  # Darker green
    MATRIX_FADE = "\033[2;32m"

    RED = "\033[91m"
    CYAN = "\033[96m"
    YELLOW = "\033[93m"


# ============================================================
#  GLOBALS
# ============================================================

attempt = 3
tasks = {}
users = {}
files = {}

# ============================================================
#  SETTINGS SYSTEM
# ============================================================

default_settings = {
    "slow_print": True,
    "boot_animation": True,
    "theme": "matrix",
    "boot_speed": "normal"
}

SETTINGS_DB = "settings.json"

def load_json(path, default):
    try:
        with open(path, "r") as f:
            return json.load(f)
    except (FileNotFoundError, json.decoder.JSONDecodeError):
        with open(path, "w") as f:
            json.dump(default, f, indent=4)
        return default

def save_json(path, data):
    with open(path, "w") as f:
        json.dump(data, f, indent=4)

settings = load_json(SETTINGS_DB, default_settings)

def save_settings():
    save_json(SETTINGS_DB, settings)


# ============================================================
#  UTILITY FUNCTIONS
# ============================================================

def slow_print(text, delay=0.03):
    if not settings.get("slow_print", True):
        print(text)
        return

    for char in text:
        sys.stdout.write(char)
        sys.stdout.flush()
        time.sleep(delay)
    print()


