import json
import time
import sys

# ============================================================
#  GLOBALS
# ============================================================

attempt = 3
users = {}
files = {}

# ============================================================
#  UTILITY FUNCTIONS
# ============================================================

def slow_print(text, delay=0.03):
    for char in text:
        sys.stdout.write(char)
        sys.stdout.flush()
        time.sleep(delay)
    print()

